# ──────────────────────────────────────────────────
# Hydra DB — OpenClaw Plugin
# Copy to .env and fill in your credentials.
# ──────────────────────────────────────────────────

# (Required) Your Hydra API key — obtain from https://app.hydradb.com
HYDRA_OPENCLAW_API_KEY=

# (Required) Your Hydra tenant identifier — shown in the Hydra dashboard
HYDRA_OPENCLAW_TENANT_ID=
